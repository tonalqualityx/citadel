generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS & AUTH
// ============================================

model User {
  id                    String    @id @default(uuid())
  email                 String    @unique
  password_hash         String
  name                  String
  role                  UserRole  @default(tech)
  avatar_url            String?
  is_active             Boolean   @default(true)
  target_hours_per_week Int       @default(40)
  last_login_at         DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  preferences           UserPreference?
  sessions              Session[]
  notifications         Notification[]
  notification_preferences NotificationPreference[]
  slack_mapping         SlackUserMapping?
  email_digest_queue    EmailDigestQueue[]
  slack_notification_batch SlackNotificationBatch[]
  projects_created      Project[]              @relation("ProjectCreatedBy")
  team_assignments      ProjectTeamAssignment[]
  user_functions        UserFunction[]
  tasks_assigned        Task[]                 @relation("TaskAssignee")
  tasks_created         Task[]                 @relation("TaskCreatedBy")
  tasks_reviewing       Task[]                 @relation("TaskReviewer")
  tasks_approved        Task[]                 @relation("TaskApprovedBy")
  time_entries          TimeEntry[]
  comments              Comment[]
  password_reset_tokens PasswordResetToken[]
  activity_logs         ActivityLog[]
  api_keys              ApiKey[]
  sites_maintained      Site[]                 @relation("SiteMaintainer")
  bug_report_notifications AppSettings[]       @relation("BugReportNotifyUser")

  @@map("users")
}

model UserPreference {
  id                  String           @id @default(uuid())
  user_id             String           @unique
  naming_convention   NamingConvention @default(awesome)
  theme               Theme            @default(system)
  notification_bundle Boolean          @default(true)
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Session {
  id            String   @id @default(uuid())
  user_id       String
  refresh_token String   @unique
  expires_at    DateTime
  created_at    DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
  @@map("sessions")
}

model ApiKey {
  id           String    @id @default(uuid())
  user_id      String
  name         String
  key_hash     String
  key_prefix   String
  last_used_at DateTime?
  expires_at   DateTime?
  is_revoked   Boolean   @default(false)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([key_hash])
  @@index([user_id])
  @@map("api_keys")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id           String           @id @default(uuid())
  user_id      String
  user         User             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  type         NotificationType
  title        String
  message      String?

  entity_type  String?
  entity_id    String?

  priority     NotificationPriority @default(normal)

  is_read      Boolean          @default(false)
  read_at      DateTime?

  bundle_key   String?
  bundle_count Int              @default(1)

  email_sent      Boolean   @default(false)
  email_sent_at   DateTime?
  slack_sent      Boolean   @default(false)
  slack_sent_at   DateTime?

  created_at   DateTime         @default(now())

  @@index([user_id])
  @@index([is_read])
  @@index([bundle_key])
  @@index([created_at])
  @@map("notifications")
}

model NotificationPreference {
  id                String           @id @default(uuid())
  user_id           String
  user              User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  notification_type NotificationType

  in_app            Boolean          @default(true)
  email             Boolean          @default(false)
  slack             Boolean          @default(false)

  admin_override    Boolean          @default(false)
  overridden_by_id  String?
  overridden_at     DateTime?

  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt

  @@unique([user_id, notification_type])
  @@index([user_id])
  @@map("notification_preferences")
}

model SlackUserMapping {
  id              String   @id @default(uuid())
  user_id         String   @unique
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  slack_user_id   String
  slack_team_id   String
  display_name    String?

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([slack_user_id])
  @@map("slack_user_mappings")
}

model SlackMessageThread {
  id              String   @id @default(uuid())

  entity_type     String
  entity_id       String

  slack_channel   String
  slack_ts        String
  slack_user_id   String

  created_at      DateTime @default(now())

  @@unique([entity_type, entity_id, slack_user_id])
  @@index([slack_ts])
  @@map("slack_message_threads")
}

model EmailDigestQueue {
  id                String           @id @default(uuid())
  user_id           String
  user              User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  notification_type NotificationType

  title             String
  message           String?
  entity_type       String?
  entity_id         String?

  processed         Boolean          @default(false)
  processed_at      DateTime?

  created_at        DateTime         @default(now())

  @@index([user_id])
  @@index([processed, created_at])
  @@map("email_digest_queue")
}

model SlackNotificationBatch {
  id                String           @id @default(uuid())
  user_id           String
  user              User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  project_id        String
  task_id           String
  notification_type NotificationType

  title             String
  message           String?

  batch_key         String
  batch_ready_at    DateTime

  processed         Boolean          @default(false)
  processed_at      DateTime?

  created_at        DateTime         @default(now())

  @@index([user_id])
  @@index([batch_key, processed])
  @@index([batch_ready_at, processed])
  @@map("slack_notification_batch")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  tech
  pm
  admin
}

enum NamingConvention {
  awesome
  standard
}

enum Theme {
  light
  dim
  dark
  system
}

enum NotificationType {
  task_assigned
  task_status_changed
  task_mentioned
  task_due_soon
  task_overdue
  project_status_changed
  review_requested
  comment_added
  retainer_alert
  system_alert
}

enum NotificationPriority {
  low
  normal
  high
  critical
}

enum MaintenanceFrequency {
  monthly
  bi_monthly
  quarterly
  semi_annually
  annually
}

// ============================================
// REFERENCE DATA
// ============================================

model Function {
  id            String   @id @default(uuid())
  name          String
  primary_focus String?
  sort_order    Int      @default(0)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  team_assignments ProjectTeamAssignment[]
  user_functions   UserFunction[]
  tasks            Task[]
  sops             Sop[]

  @@map("functions")
}

model UserFunction {
  id          String   @id @default(uuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  function_id String
  function    Function @relation(fields: [function_id], references: [id], onDelete: Cascade)
  is_primary  Boolean  @default(false)
  created_at  DateTime @default(now())

  @@unique([user_id, function_id])
  @@index([user_id])
  @@index([function_id])
  @@map("user_functions")
}

model HostingPlan {
  id           String   @id @default(uuid())
  name         String
  rate         Float
  agency_rate  Float?
  monthly_cost Float?
  vendor_plan  String?
  details      String?
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  sites Site[]

  @@map("hosting_plans")
}

model MaintenancePlan {
  id          String               @id @default(uuid())
  name        String
  rate        Float
  agency_rate Float?
  hours       Float?
  details     String?
  frequency   MaintenanceFrequency @default(monthly)
  is_active   Boolean              @default(true)
  created_at  DateTime             @default(now())
  updated_at  DateTime             @updatedAt

  sites           Site[]
  sops            MaintenancePlanSop[]
  generation_logs MaintenanceGenerationLog[]

  @@map("maintenance_plans")
}

model MaintenancePlanSop {
  id                  String          @id @default(uuid())
  maintenance_plan_id String
  maintenance_plan    MaintenancePlan @relation(fields: [maintenance_plan_id], references: [id], onDelete: Cascade)
  sop_id              String
  sop                 Sop             @relation(fields: [sop_id], references: [id], onDelete: Cascade)
  sort_order          Int             @default(0)

  @@unique([maintenance_plan_id, sop_id])
  @@index([maintenance_plan_id])
  @@index([sop_id])
  @@map("maintenance_plan_sops")
}

model Tool {
  id          String   @id @default(uuid())
  name        String
  category    String?
  url         String?
  description String?
  license_key String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("tools")
}

model Integration {
  id          String   @id @default(uuid())
  provider    String   @unique
  config      Json     @default("{}")
  is_active   Boolean  @default(false)
  updated_at  DateTime @updatedAt
  updated_by  String?

  @@map("integrations")
}

model DnsProvider {
  id        String   @id @default(uuid())
  name      String   @unique
  is_active Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  domains   Domain[]

  @@map("dns_providers")
}

// ============================================
// CLIENTS (PATRONS)
// ============================================

model Client {
  id              String       @id @default(uuid())
  name            String
  type            ClientType   @default(direct)
  status          ClientStatus @default(active)

  primary_contact String?
  email           String?
  phone           String?

  retainer_hours      Float?
  hourly_rate         Float?
  retainer_usage_mode RetainerUsageMode  @default(medium)

  parent_agency_id String?
  parent_agency    Client?     @relation("AgencySubClients", fields: [parent_agency_id], references: [id])
  sub_clients      Client[]    @relation("AgencySubClients")

  notes           String?

  is_deleted      Boolean      @default(false)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  sites    Site[]
  projects Project[]
  tasks    Task[]

  @@index([type])
  @@index([status])
  @@index([parent_agency_id])
  @@map("clients")
}

enum ClientType {
  direct
  agency_partner
  sub_client
}

enum ClientStatus {
  active
  inactive
  delinquent
}

enum RetainerUsageMode {
  low
  medium
  high
  actual
}

// ============================================
// SITES
// ============================================

model Site {
  id                  String           @id @default(uuid())
  name                String
  url                 String?

  client_id           String?
  client              Client?          @relation(fields: [client_id], references: [id])

  hosted_by           HostedBy         @default(indelible)
  platform            String?
  hosting_plan_id     String?
  hosting_plan        HostingPlan?     @relation(fields: [hosting_plan_id], references: [id])
  hosting_discount    Float?

  maintenance_plan_id      String?
  maintenance_plan         MaintenancePlan? @relation(fields: [maintenance_plan_id], references: [id])
  maintenance_assignee_id  String?
  maintenance_assignee     User?            @relation("SiteMaintainer", fields: [maintenance_assignee_id], references: [id])

  notes               String?

  is_deleted          Boolean          @default(false)
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt

  domains                   Domain[]
  projects                  Project[]
  tasks                     Task[]
  maintenance_generation_logs MaintenanceGenerationLog[]

  @@index([client_id])
  @@index([hosting_plan_id])
  @@index([maintenance_plan_id])
  @@index([maintenance_assignee_id])
  @@map("sites")
}

enum HostedBy {
  indelible
  client
  other
}

// ============================================
// DOMAINS
// ============================================

model Domain {
  id         String    @id @default(uuid())
  name       String

  site_id    String?
  site       Site?     @relation(fields: [site_id], references: [id])

  registrar  String?
  expires_at DateTime?
  is_primary Boolean   @default(false)

  registered_by  DomainOwnership?

  dns_provider_id String?
  dns_provider    DnsProvider? @relation(fields: [dns_provider_id], references: [id])
  dns_managed_by  DomainOwnership?

  notes      String?

  is_deleted Boolean   @default(false)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@index([site_id])
  @@index([dns_provider_id])
  @@map("domains")
}

enum DomainOwnership {
  indelible
  client
}

// ============================================
// PROJECTS (PACTS)
// ============================================

model Project {
  id              String        @id @default(uuid())
  name            String
  description     String?

  status          ProjectStatus @default(quote)

  client_id       String
  client          Client        @relation(fields: [client_id], references: [id])
  site_id         String?
  site            Site?         @relation(fields: [site_id], references: [id])
  recipe_id       String?
  recipe          Recipe?       @relation(fields: [recipe_id], references: [id])

  type            ProjectType   @default(project)

  start_date      DateTime?
  target_date     DateTime?
  completed_date  DateTime?

  billing_type      BillingType?
  budget_hours      Float?
  hourly_rate       Float?
  budget_amount     Float?
  budget_locked     Boolean       @default(false)
  budget_locked_at  DateTime?
  budget_locked_by_id String?
  is_retainer       Boolean       @default(false)

  notes           String?

  is_deleted      Boolean       @default(false)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  created_by_id   String?
  created_by      User?         @relation("ProjectCreatedBy", fields: [created_by_id], references: [id])

  phases           ProjectPhase[]
  tasks            Task[]
  team_assignments ProjectTeamAssignment[]
  milestones       Milestone[]
  time_entries     TimeEntry[]
  pages            ProjectPage[]
  resource_links   ResourceLink[]
  app_settings_bug_report AppSettings[]

  @@index([client_id])
  @@index([recipe_id])
  @@index([site_id])
  @@index([status])
  @@index([type])
  @@map("projects")
}

model ProjectPhase {
  id          String   @id @default(uuid())
  project_id  String
  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  name        String
  icon        String?
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tasks       Task[]
  milestones  Milestone[]
  app_settings_bug_report AppSettings[]

  @@index([project_id])
  @@map("project_phases")
}

enum ProjectStatus {
  quote
  queue
  ready
  in_progress
  review
  done
  suspended
  cancelled
}

enum ProjectType {
  project
  retainer
  internal
}

enum BillingType {
  fixed
  hourly
  retainer
  none
}

model ResourceLink {
  id          String   @id @default(uuid())
  project_id  String
  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  name        String
  url         String
  icon        String?
  sort_order  Int      @default(0)
  is_deleted  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([project_id])
  @@map("resource_links")
}

model ProjectTeamAssignment {
  id          String   @id @default(uuid())
  project_id  String
  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user_id     String
  user        User     @relation(fields: [user_id], references: [id])
  function_id String
  function    Function @relation(fields: [function_id], references: [id])
  is_lead     Boolean  @default(false)
  created_at  DateTime @default(now())

  @@unique([project_id, function_id])
  @@index([project_id])
  @@index([user_id])
  @@index([function_id])
  @@map("project_team_assignments")
}

// ============================================
// TASKS (QUESTS)
// ============================================

model Task {
  id                String        @id @default(uuid())
  title             String
  description       String?

  status            TaskStatus    @default(not_started)
  priority          Int           @default(3)
  is_focus          Boolean       @default(false)

  project_id        String?
  project           Project?      @relation(fields: [project_id], references: [id])

  client_id         String?
  client            Client?       @relation(fields: [client_id], references: [id])

  site_id           String?
  site              Site?         @relation(fields: [site_id], references: [id])

  is_maintenance_task  Boolean    @default(false)
  maintenance_period   String?

  phase             String?
  phase_id          String?
  project_phase     ProjectPhase? @relation(fields: [phase_id], references: [id])
  sort_order        Int           @default(0)

  assignee_id       String?
  assignee          User?         @relation("TaskAssignee", fields: [assignee_id], references: [id])
  function_id       String?
  function          Function?     @relation(fields: [function_id], references: [id])

  energy_estimate   Int?
  mystery_factor    MysteryFactor @default(none)
  estimated_minutes Int?
  battery_impact    BatteryImpact @default(average_drain)

  due_date          DateTime?
  started_at        DateTime?
  completed_at      DateTime?

  requirements        Json?
  review_requirements Json?

  needs_review        Boolean       @default(true)
  reviewer_id         String?
  reviewer            User?         @relation("TaskReviewer", fields: [reviewer_id], references: [id])
  approved            Boolean       @default(false)
  approved_at         DateTime?
  approved_by_id      String?
  approved_by         User?         @relation("TaskApprovedBy", fields: [approved_by_id], references: [id])

  sop_id            String?
  sop               Sop?          @relation(fields: [sop_id], references: [id])

  invoiced          Boolean       @default(false)
  invoiced_at       DateTime?
  invoiced_by_id    String?
  is_billable       Boolean       @default(true)
  billing_target    Float?
  is_retainer_work  Boolean       @default(false)
  is_support        Boolean       @default(false)
  billing_amount    Float?
  waive_overage     Boolean       @default(false)

  no_time_needed    Boolean       @default(false)

  notes             String?

  is_deleted        Boolean       @default(false)
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt
  created_by_id     String?
  created_by        User?         @relation("TaskCreatedBy", fields: [created_by_id], references: [id])

  blocked_by        Task[]        @relation("TaskDependencies")
  blocking          Task[]        @relation("TaskDependencies")

  time_entries      TimeEntry[]
  comments          Comment[]

  @@index([project_id])
  @@index([client_id])
  @@index([site_id])
  @@index([assignee_id])
  @@index([status])
  @@index([priority])
  @@index([phase])
  @@index([phase_id])
  @@index([sop_id])
  @@index([invoiced])
  @@index([is_maintenance_task])
  @@index([is_support])
  @@map("tasks")
}

enum TaskStatus {
  not_started
  in_progress
  review
  done
  blocked
  abandoned
}

enum MysteryFactor {
  none
  average
  significant
  no_idea
}

enum BatteryImpact {
  average_drain
  high_drain
  energizing
}

enum MilestoneBillingStatus {
  pending
  triggered
  invoiced
}

model Milestone {
  id           String    @id @default(uuid())
  name         String
  project_id   String
  project      Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)

  phase_id     String?
  phase        ProjectPhase? @relation(fields: [phase_id], references: [id])

  target_date  DateTime?
  completed_at DateTime?
  notes        String?
  sort_order   Int       @default(0)

  billing_amount    Float?
  billing_status    MilestoneBillingStatus @default(pending)
  triggered_at      DateTime?
  triggered_by_id   String?
  invoiced_at       DateTime?
  invoiced_by_id    String?

  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@index([project_id])
  @@index([phase_id])
  @@index([billing_status])
  @@map("milestones")
}

model Recipe {
  id               String        @id @default(uuid())
  name             String
  description      Json?

  default_type     ProjectType   @default(project)
  requires_sitemap Boolean       @default(false)

  is_active        Boolean       @default(true)
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  phases           RecipePhase[]
  projects         Project[]

  @@map("recipes")
}

model RecipePhase {
  id          String       @id @default(uuid())
  recipe_id   String
  recipe      Recipe       @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  name        String
  icon        String?
  sort_order  Int          @default(0)

  tasks       RecipeTask[]

  @@index([recipe_id])
  @@map("recipe_phases")
}

model RecipeTask {
  id              String      @id @default(uuid())
  phase_id        String
  phase           RecipePhase @relation(fields: [phase_id], references: [id], onDelete: Cascade)

  sop_id          String
  sop             Sop         @relation(fields: [sop_id], references: [id])

  title           String?

  is_variable     Boolean     @default(false)
  variable_source String?

  sort_order      Int         @default(0)

  depends_on_ids  String

  @@index([phase_id])
  @@index([sop_id])
  @@map("recipe_tasks")
}

model Sop {
  id                    String    @id @default(uuid())
  title                 String

  content               Json?

  function_id           String?
  function              Function? @relation(fields: [function_id], references: [id])
  tags                  String    @default("[]")

  default_priority      Int           @default(3)
  energy_estimate       Int?
  mystery_factor        MysteryFactor @default(none)
  battery_impact        BatteryImpact @default(average_drain)
  estimated_minutes     Int?
  needs_review          Boolean       @default(true)

  template_requirements Json?
  setup_requirements    Json?
  review_requirements   Json?

  last_reviewed_at      DateTime?
  next_review_at        DateTime?

  is_active             Boolean   @default(true)
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  tasks                 Task[]
  recipe_tasks          RecipeTask[]
  maintenance_plan_sops MaintenancePlanSop[]

  @@index([function_id])
  @@map("sops")
}

model ProjectPage {
  id            String   @id @default(uuid())
  project_id    String
  project       Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  name          String
  page_type     String?
  needs_design  Boolean  @default(false)
  notes         String?
  sort_order    Int      @default(0)

  @@index([project_id])
  @@map("project_pages")
}

model TimeEntry {
  id          String   @id @default(uuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id])
  task_id     String?
  task        Task?    @relation(fields: [task_id], references: [id])
  project_id  String?
  project     Project? @relation(fields: [project_id], references: [id])

  started_at  DateTime
  ended_at    DateTime?
  duration    Int       @default(0)
  is_running  Boolean   @default(false)
  description String?

  is_billable Boolean  @default(true)
  hourly_rate Float?

  is_deleted  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([user_id])
  @@index([task_id])
  @@index([project_id])
  @@index([started_at])
  @@index([is_running])
  @@map("time_entries")
}

model ActivityLog {
  id          String   @id @default(uuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id])
  action      String
  entity_type String
  entity_id   String
  entity_name String?
  changes     Json?
  created_at  DateTime @default(now())

  @@index([entity_type, entity_id])
  @@index([user_id])
  @@index([created_at])
  @@map("activity_logs")
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  user_id    String
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  token      String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  @@index([token])
  @@index([user_id])
  @@index([expires_at])
  @@map("password_reset_tokens")
}

model Comment {
  id         String   @id @default(uuid())
  task_id    String
  task       Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  content    String
  is_deleted Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([task_id])
  @@index([user_id])
  @@index([created_at])
  @@map("comments")
}

model MaintenanceGenerationLog {
  id                  String          @id @default(uuid())
  maintenance_plan_id String
  maintenance_plan    MaintenancePlan @relation(fields: [maintenance_plan_id], references: [id], onDelete: Cascade)
  site_id             String
  site                Site            @relation(fields: [site_id], references: [id], onDelete: Cascade)
  period              String
  tasks_created       Int
  tasks_abandoned     Int             @default(0)
  generated_at        DateTime        @default(now())

  @@unique([maintenance_plan_id, site_id, period])
  @@index([maintenance_plan_id])
  @@index([site_id])
  @@index([period])
  @@map("maintenance_generation_logs")
}

model AppSettings {
  id                          String    @id @default("singleton")

  bug_report_project_id       String?
  bug_report_phase_id         String?
  bug_report_notify_user_id   String?

  created_at                  DateTime  @default(now())
  updated_at                  DateTime  @updatedAt

  bug_report_project          Project?      @relation(fields: [bug_report_project_id], references: [id])
  bug_report_phase            ProjectPhase? @relation(fields: [bug_report_phase_id], references: [id])
  bug_report_notify_user      User?         @relation("BugReportNotifyUser", fields: [bug_report_notify_user_id], references: [id])

  @@map("app_settings")
}
