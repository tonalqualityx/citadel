  msa_version     MsaVersion @relation(fields: [msa_version_id], references: [id])
  signed_at       DateTime
  signer_name     String     @db.VarChar(255)
  signer_email    String     @db.VarChar(255)
  signer_ip       String?    @db.VarChar(45)
  signer_user_agent String?  @db.Text
  portal_token    String?    @db.VarChar(128)
  created_at      DateTime   @default(now())

  @@unique([client_id, msa_version_id])
  @@index([client_id])
  @@map("client_msa_signatures")
}

model Charter {
  id                  String               @id @default(uuid()) @db.Uuid
  name                String               @db.VarChar(255)
  client_id           String               @db.Uuid
  client              Client               @relation(fields: [client_id], references: [id])
  accord_id           String?              @db.Uuid
  accord              Accord?              @relation(fields: [accord_id], references: [id])
  status              CharterStatus        @default(active)
  billing_period      CharterBillingPeriod
  budget_hours        Decimal?             @db.Decimal(6, 2)
  hourly_rate         Decimal?             @db.Decimal(8, 2)
  budget_amount       Decimal?             @db.Decimal(10, 2)
  start_date          DateTime             @db.Date
  end_date            DateTime?            @db.Date
  duration_months     Int?
  renewal_date        DateTime?            @db.Date
  site_id             String?              @db.Uuid
  site                Site?                @relation(fields: [site_id], references: [id])
  paused_at           DateTime?
  cancelled_at        DateTime?
  cancellation_reason String?              @db.Text
  created_by_id       String               @db.Uuid
  created_by          User                 @relation("CharterCreatedBy", fields: [created_by_id], references: [id])
  is_deleted          Boolean              @default(false)
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt

  // Relations
  charter_wares          CharterWare[]
  scheduled_tasks        CharterScheduledTask[]
  generation_logs        CharterGenerationLog[]
  charter_commissions    CharterCommission[]
  charter_items          AccordCharterItem[]
  renewal_logs           CharterRenewalLog[]
  tasks                  Task[]
  meeting_charters       MeetingCharter[]

  @@index([client_id])
  @@index([accord_id])
  @@index([status])
  @@index([site_id])
  @@map("charters")
}

model CharterWare {
  id                   String          @id @default(uuid()) @db.Uuid
  charter_id           String          @db.Uuid
  charter              Charter         @relation(fields: [charter_id], references: [id], onDelete: Cascade)
  ware_id              String          @db.Uuid
  ware                 Ware            @relation(fields: [ware_id], references: [id])
  price                Decimal         @db.Decimal(10, 2)
  is_active            Boolean         @default(true)
  deactivated_at       DateTime?
  addendum_id          String?         @db.Uuid
  created_at           DateTime        @default(now())
  updated_at           DateTime        @updatedAt

  // Relations
  scheduled_tasks CharterScheduledTask[]

  @@index([charter_id])
  @@index([ware_id])
  @@map("charter_wares")
}

model CharterScheduledTask {
  id              String       @id @default(uuid()) @db.Uuid
  charter_id      String       @db.Uuid
  charter         Charter      @relation(fields: [charter_id], references: [id], onDelete: Cascade)
  charter_ware_id String?      @db.Uuid
  charter_ware    CharterWare? @relation(fields: [charter_ware_id], references: [id])
  sop_id          String       @db.Uuid
  sop             Sop          @relation(fields: [sop_id], references: [id])
  cadence         String       @db.VarChar(20)
  sort_order      Int          @default(0)
  is_active       Boolean      @default(true)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  // Relations
  generation_logs CharterGenerationLog[]

  @@index([charter_id])
  @@index([sop_id])
  @@map("charter_scheduled_tasks")
}

model CharterGenerationLog {
  id                String               @id @default(uuid()) @db.Uuid
  charter_id        String               @db.Uuid
  charter           Charter              @relation(fields: [charter_id], references: [id], onDelete: Cascade)
  scheduled_task_id String               @db.Uuid
  scheduled_task    CharterScheduledTask @relation(fields: [scheduled_task_id], references: [id], onDelete: Cascade)
  period            String               @db.VarChar(20)
  tasks_created     Int
  tasks_abandoned   Int                  @default(0)
  generated_at      DateTime             @default(now())

  @@unique([charter_id, scheduled_task_id, period])
  @@index([charter_id])
  @@map("charter_generation_logs")
}

model CharterCommission {
  id                         String    @id @default(uuid()) @db.Uuid
  charter_id                 String    @db.Uuid
  charter                    Charter   @relation(fields: [charter_id], references: [id], onDelete: Cascade)
  commission_id              String    @db.Uuid
  commission                 Project   @relation(fields: [commission_id], references: [id])
  allocated_hours_per_period Decimal?  @db.Decimal(6, 2)
  start_period               String    @db.VarChar(20)
  end_period                 String?   @db.VarChar(20)
  is_active                  Boolean   @default(true)
  completed_at               DateTime?
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt

  @@index([charter_id])
  @@index([commission_id])
  @@map("charter_commissions")
}

model PortalSession {
