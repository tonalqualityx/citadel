}

model SalesAutomationLog {
  id          String   @id @default(uuid()) @db.Uuid
  rule_id     String   @db.Uuid
  rule        SalesAutomationRule @relation(fields: [rule_id], references: [id], onDelete: Cascade)
  accord_id   String   @db.Uuid
  accord      Accord   @relation(fields: [accord_id], references: [id], onDelete: Cascade)
  task_id     String?  @db.Uuid
  fired_at    DateTime @default(now())

  @@unique([rule_id, accord_id])
  @@index([accord_id])
  @@map("sales_automation_logs")
}
