  @@map("portal_sessions")
}

model SalesAutomationRule {
  id                   String       @id @default(uuid()) @db.Uuid
  name                 String       @db.VarChar(255)
  trigger_type         String       @db.VarChar(20)
  trigger_status       AccordStatus
  trigger_from_status  AccordStatus?
  time_threshold_hours Int?
  action_type          String       @db.VarChar(20)
  task_template        Json
  assignee_rule        String       @db.VarChar(20)
  assignee_user_id     String?      @db.Uuid
  assignee_user        User?        @relation("SalesAutomationAssignee", fields: [assignee_user_id], references: [id])
  is_active            Boolean      @default(true)
  sort_order           Int          @default(0)
  created_at           DateTime     @default(now())
  updated_at           DateTime     @updatedAt

  @@index([trigger_status])
