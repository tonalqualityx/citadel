  client_note           String?        @db.Text
  portal_token          String?        @db.VarChar(128)
  portal_token_expires_at DateTime?
  created_by_id         String         @db.Uuid
  created_by            User           @relation("ProposalCreatedBy", fields: [created_by_id], references: [id])
  is_deleted            Boolean        @default(false)
  created_at            DateTime       @default(now())
  updated_at            DateTime       @updatedAt

  @@unique([accord_id, version])
  @@index([accord_id])
  @@index([portal_token])
  @@map("proposals")
}

model MsaVersion {
  id             String   @id @default(uuid()) @db.Uuid
  version        String   @db.VarChar(20)
  content        String   @db.Text
  effective_date DateTime @db.Date
  is_current     Boolean  @default(false)
  change_summary String?  @db.Text
  created_by_id  String   @db.Uuid
  created_by     User     @relation("MsaVersionCreatedBy", fields: [created_by_id], references: [id])
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Relations
  contracts            Contract[]
  client_msa_signatures ClientMsaSignature[]

  @@map("msa_versions")
}

model Contract {
  id                    String         @id @default(uuid()) @db.Uuid
  accord_id             String         @db.Uuid
  accord                Accord         @relation(fields: [accord_id], references: [id], onDelete: Cascade)
  version               Int
  content               String         @db.Text
  msa_version_id        String         @db.Uuid
  msa_version           MsaVersion     @relation(fields: [msa_version_id], references: [id])
  status                ContractStatus @default(draft)
  pricing_snapshot      Json
  sent_at               DateTime?
  signed_at             DateTime?
  signer_name           String?        @db.VarChar(255)
  signer_email          String?        @db.VarChar(255)
  signer_ip             String?        @db.VarChar(45)
  signer_user_agent     String?        @db.Text
  content_snapshot      String?        @db.Text
  portal_token          String?        @db.VarChar(128)
  portal_token_expires_at DateTime?
  created_by_id         String         @db.Uuid
  created_by            User           @relation("ContractCreatedBy", fields: [created_by_id], references: [id])
  is_deleted            Boolean        @default(false)
  created_at            DateTime       @default(now())
  updated_at            DateTime       @updatedAt

  @@unique([accord_id, version])
  @@index([accord_id])
  @@index([portal_token])
  @@map("contracts")
}

model Addendum {
  id                    String         @id @default(uuid()) @db.Uuid
  accord_id             String         @db.Uuid
  accord                Accord         @relation(fields: [accord_id], references: [id], onDelete: Cascade)
  version               Int
  title                 String         @db.VarChar(255)
  description           String         @db.Text
  contract_content      String         @db.Text
  status                AddendumStatus @default(draft)
  pricing_snapshot      Json
  changes               Json
  sent_at               DateTime?
  client_responded_at   DateTime?
  client_note           String?        @db.Text
  signed_at             DateTime?
  signer_name           String?        @db.VarChar(255)
  signer_email          String?        @db.VarChar(255)
  signer_ip             String?        @db.VarChar(45)
  signer_user_agent     String?        @db.Text
  content_snapshot      String?        @db.Text
  portal_token          String?        @db.VarChar(128)
  portal_token_expires_at DateTime?
  is_override           Boolean        @default(false)
  override_reason       String?        @db.Text
  overridden_by_id      String?        @db.Uuid
  overridden_by         User?          @relation("AddendumOverriddenBy", fields: [overridden_by_id], references: [id])
  created_by_id         String         @db.Uuid
  created_by            User           @relation("AddendumCreatedBy", fields: [created_by_id], references: [id])
  is_deleted            Boolean        @default(false)
