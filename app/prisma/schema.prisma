model AccordCommissionItem {
  id                         String    @id @default(uuid()) @db.Uuid
  accord_id                  String    @db.Uuid
  accord                     Accord    @relation(fields: [accord_id], references: [id], onDelete: Cascade)
  ware_id                    String    @db.Uuid
  ware                       Ware      @relation(fields: [ware_id], references: [id])
  name_override              String?   @db.VarChar(255)
  estimated_price            Decimal?  @db.Decimal(10, 2)
  project_id                 String?   @db.Uuid
  project                    Project?  @relation(fields: [project_id], references: [id])
  discount_type              String?   @db.VarChar(10)
  discount_value             Decimal?  @db.Decimal(10, 2)
  final_price                Decimal?  @db.Decimal(10, 2)
  contract_language_override String?   @db.Text
  addendum_id                String?   @db.Uuid
  addendum                   Addendum? @relation(fields: [addendum_id], references: [id])
  sort_order                 Int       @default(0)
  is_deleted                 Boolean   @default(false)
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt

  @@index([accord_id])
  @@index([ware_id])
  @@index([project_id])
  @@index([addendum_id])
  @@map("accord_commission_items")
}

model AccordKeepItem {
  id                           String           @id @default(uuid()) @db.Uuid
  accord_id                    String           @db.Uuid
  accord                       Accord           @relation(fields: [accord_id], references: [id], onDelete: Cascade)
  site_id                      String?          @db.Uuid
  site                         Site?            @relation(fields: [site_id], references: [id])
  site_name_placeholder        String?          @db.VarChar(255)
  domain_name                  String?          @db.VarChar(255)
  hosting_plan_id              String?          @db.Uuid
  hosting_plan                 HostingPlan?     @relation("KeepHostingPlan", fields: [hosting_plan_id], references: [id])
  maintenance_plan_id          String?          @db.Uuid
  maintenance_plan             MaintenancePlan? @relation("KeepMaintenancePlan", fields: [maintenance_plan_id], references: [id])
  hosting_price                Decimal?         @db.Decimal(10, 2)
  hosting_discount_type        String?          @db.VarChar(10)
  hosting_discount_value       Decimal?         @db.Decimal(10, 2)
  hosting_final_price          Decimal?         @db.Decimal(10, 2)
  maintenance_price            Decimal?         @db.Decimal(10, 2)
  maintenance_discount_type    String?          @db.VarChar(10)
  maintenance_discount_value   Decimal?         @db.Decimal(10, 2)
  maintenance_final_price      Decimal?         @db.Decimal(10, 2)
  monthly_total                Decimal?         @db.Decimal(10, 2)
  is_client_hosted             Boolean          @default(false)
  contract_language_override   String?          @db.Text
  addendum_id                  String?          @db.Uuid
  addendum                     Addendum?        @relation(fields: [addendum_id], references: [id])
  sort_order                   Int              @default(0)
  is_deleted                   Boolean          @default(false)
  created_at                   DateTime         @default(now())
  updated_at                   DateTime         @updatedAt

  @@index([accord_id])
  @@index([site_id])
  @@index([hosting_plan_id])
  @@index([maintenance_plan_id])
  @@index([addendum_id])
  @@map("accord_keep_items")
}

model CharterRenewalLog {
  id           String   @id @default(uuid()) @db.Uuid
  charter_id   String   @db.Uuid
  charter      Charter  @relation(fields: [charter_id], references: [id])
  renewal_date DateTime @db.Date
  task_id      String?  @db.Uuid
  task         Task?    @relation(fields: [task_id], references: [id])
  accord_id    String?  @db.Uuid
  accord       Accord?  @relation(fields: [accord_id], references: [id])
  created_at   DateTime @default(now())

  @@unique([charter_id, renewal_date])
  @@index([charter_id])
  @@index([accord_id])
  @@map("charter_renewal_logs")
}

model Proposal {
